        except Exception:
            return False

    def get_activation_token(self, token: str) -> Optional[Dict]:
        """Lee un token. Retorna None si no existe, expirado o ya usado."""
        with self._conn() as c:
            row = c.execute(
                "SELECT * FROM activation_tokens WHERE token=?", (token,)
            ).fetchone()
        if not row:
            return None
        data = dict(row)
        # Verificar expiracion
        try:
            exp = datetime.fromisoformat(data["expires_at"])
            if datetime.now() > exp:
                return None
        except Exception:
            return None
        # Verificar si ya fue usado
        if data.get("used_at") and data.get("is_active") == 0:
            return None
        return data

