def cmd_init(args):
    """Configuración inicial de Melissa en este servidor."""
    print_logo(animated=True)
    section("Bienvenido a Melissa", "Vamos a configurar tu servidor.")

    ghost_write("Melissa es la recepcionista virtual para tus clínicas estéticas.", C.G1)
    ghost_write("Responde WhatsApp y Telegram, agenda citas, aprende de tu negocio.", C.G1)
    print()

    # Verificar dependencias
    section("Verificando dependencias")

    deps = [("python3", "Python 3"), ("pm2", "PM2"), ("curl", "curl")]
    all_ok = True
    for cmd_name, label in deps:
        if shutil.which(cmd_name):
            ok(f"{label} encontrado")
        else:
            fail(f"{label} NO encontrado")
            all_ok = False

    if not all_ok:
        print()
        warn("Faltan dependencias. Instala PM2 con: npm install -g pm2")
        return

    # Verificar archivos
    section("Verificando archivos de Melissa")
    required = ["melissa.py", "search.py", "knowledge_base.py"]
    for f in required:
        path = f"{MELISSA_DIR}/{f}"
        if os.path.exists(path):
            ok(f"{f}")
        else:
            warn(f"{f} no encontrado en {MELISSA_DIR}")

    # Verificar .env
    env_path = f"{MELISSA_DIR}/.env"
    if not os.path.exists(env_path):
        fail(f".env no encontrado en {MELISSA_DIR}")
        info("Crea el .env con: cp .env.example .env  y rellena las claves")
        return

    env = load_env(env_path)
    print()

    # Verificar claves críticas
    section("Verificando configuración")
    checks = [
        ("TELEGRAM_TOKEN", "Telegram bot"),
        ("GROQ_API_KEY", "Groq LLM"),
        ("BASE_URL", "URL pública"),
        ("MASTER_API_KEY", "Master API key"),
    ]
    for key, label in checks:
        if env.get(key):
            ok(f"{label}")
        else:
            warn(f"{label} no configurado ({key})")

    # IP pública
    print()
    with Spinner("Detectando IP pública del servidor...", "melissa") as sp:
        ip = public_ip()
        sp.finish(f"IP pública: {ip}" if ip else "No pude detectar IP pública")

    # Arrancar Melissa si no está corriendo
    h = health(int(env.get("PORT", BASE_PORT)))
    if h:
        ok(f"Melissa ya está corriendo en puerto {env.get('PORT', BASE_PORT)}")
    else:
        print()
        if confirm("Arrancar Melissa ahora?"):
            start_sh = f"{MELISSA_DIR}/start.sh"
            if os.path.exists(start_sh):
                with Spinner("Arrancando Melissa...", "melissa") as sp:
                    subprocess.run(["bash", start_sh], cwd=MELISSA_DIR,
                                   capture_output=True)
                    time.sleep(3)
                    h = health(int(env.get("PORT", BASE_PORT)))
                    sp.finish("Melissa online" if h else "Arrancando (puede tardar unos segundos)")
            else:
                warn("start.sh no encontrado. Arranca manualmente: pm2 start melissa.py --interpreter python3")

    print()
    section("Todo listo")
    ghost_write("Usa 'melissa new' para crear tu primer cliente.", C.P2)
    ghost_write("Usa 'melissa list' para ver las instancias activas.", C.P2)
    ghost_write("Usa 'melissa chat' para hablarme en lenguaje natural.", C.P2)
    print()


def cmd_list(args):
    """Ver todas las instancias de Melissa."""
    print_logo(compact=True)
    section("Instancias activas")

    instances = get_instances()
    if not instances:
        warn("No hay instancias. Crea una con: melissa new")
        return

    # Health de todas en paralelo
    import concurrent.futures
    with concurrent.futures.ThreadPoolExecutor(max_workers=10) as ex:
        healths = list(ex.map(lambda i: health(i["port"]), instances))

    for inst, h in zip(instances, healths):
        icon, status = get_status_icon(h)
        port      = inst["port"]
        platform  = h.get("platform", inst["env"].get("PLATFORM", "telegram"))
        wa        = h.get("whatsapp", {})
        plat_str  = f"WA {wa.get('phone','')}" if wa.get("connected") else platform
        clinic    = h.get("clinic", inst["label"])
        nova_on   = inst["env"].get("NOVA_ENABLED", "false") == "true"
        nova_str  = q(C.P3, " ✦Nova") if nova_on else ""
        mem       = h.get("memory_items", "")
        mem_str   = q(C.G3, f"  {mem} mem") if mem else ""

        print(f"  {icon}  {q(C.W, clinic, bold=True)}{nova_str}")
        print(f"       {q(C.G2, inst['name'])}  ·  :{port}  ·  {q(C.G1, plat_str)}{mem_str}")
        print()


