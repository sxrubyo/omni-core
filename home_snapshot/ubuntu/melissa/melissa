            "# Base de datos — aislada por cliente",
            f"DB_PATH={inst_dir}/melissa.db",
            f"VECTOR_DB_PATH={inst_dir}/vectors.db",
            "",
            "# Seguridad",
            f"MASTER_API_KEY={master_key}",
            "",
            "# Timing",
            "BUFFER_WAIT_MIN=35",
            "BUFFER_WAIT_MAX=55",
            "BUBBLE_PAUSE_MIN=1.0",
            "BUBBLE_PAUSE_MAX=3.0",
            "",
            "# WhatsApp (configurar con /whatsapp en Telegram)",
            "WA_PHONE_ID=",
            "WA_ACCESS_TOKEN=",
            "WA_VERIFY_TOKEN=",
            f"META_APP_ID={shared['META_APP_ID']}",
            f"META_APP_SECRET={shared['META_APP_SECRET']}",
            "",
            "# Nova",
            f"NOVA_URL=http://localhost:{NOVA_PORT}",
            "NOVA_API_KEY=",
            "NOVA_TOKEN=",
            "NOVA_ENABLED=false",
            "",
            "# Omni",
            f"OMNI_URL=http://localhost:{OMNI_PORT}",
            f"OMNI_KEY={base_env.get('OMNI_KEY', '')}",
        ]
        Path(f"{inst_dir}/.env").write_text("\n".join(env_lines))

        # Metadata
        Path(f"{inst_dir}/instance.json").write_text(json.dumps({
            "name": name, "label": name_raw, "port": port,
            "base_url": base_url, "master_key": master_key,
            "created_at": datetime.utcnow().isoformat() + "Z",
        }, indent=2))

        sp.finish(f"Instancia '{name}' creada")

    # Lanzar con PM2
    pm2_name = f"melissa-{name}"
    with Spinner(f"Arrancando {pm2_name}...", "melissa") as sp:
        pm2("delete", pm2_name)  # limpiar si existía
        r = subprocess.run([
            "pm2", "start", f"{inst_dir}/melissa.py",
            "--name", pm2_name,
            "--interpreter", "python3",
            "--restart-delay", "3000",
            "--max-restarts", "10",
            "--log", f"{inst_dir}/logs/melissa.log",
            "--error", f"{inst_dir}/logs/error.log",
        ], capture_output=True, text=True)
        subprocess.run(["pm2", "save"], capture_output=True)
        time.sleep(4)
        h = health(port)
        sp.finish("Online" if h else "Arrancando (puede tardar unos segundos)", ok=bool(h))

    # ¿Integrar Nova?
    nova_h = health(NOVA_PORT)
    if nova_h:
        print()
        if confirm("Nova está activo. ¿Quieres que gobierne esta instancia?"):
            _connect_nova_to_instance(inst_dir, name, master_key)

    # Resumen
    print()
    section(f"'{name_raw}' lista")
    kv("Instancia",   name)
    kv("Puerto",      str(port))
    kv("URL",         base_url)
    kv("Master Key",  master_key)
    kv("PM2",         pm2_name)
    print()
    info(f"Siguiente paso: abre el bot en Telegram y envía el token de activación")
    info(f"Para generar un token: melissa chat → 'dame el token para {name_raw}'")
    print()


def _connect_nova_to_instance(inst_dir, name, master_key):
    """Conectar una instancia específica con Nova."""
    with Spinner("Creando agente Nova...", "melissa") as sp:
        base_env = load_env(f"{MELISSA_DIR}/.env")
        nova_api_key = base_env.get("NOVA_API_KEY", "")
        try:
            if _HTTPX:
                import httpx
                r = httpx.post(
                    f"http://localhost:{NOVA_PORT}/tokens",
                    json={
                        "agent_name": f"Melissa - {name}",
                        "description": "Recepcionista virtual clínica estética",
                        "can_do": ["send appointment confirmations",
                                   "answer questions about clinic services",
                                   "book free consultation appointments"],
                        "cannot_do": ["provide medical diagnosis",
                                      "share patient personal information",
                                      "guarantee treatment results"],
                        "authorized_by": "Santiago"
                    },
                    headers={"Authorization": f"Bearer {nova_api_key}",
                             "X-API-Key": nova_api_key},
                    timeout=10
                )
                if r.status_code == 200:
                    token_id = r.json().get("token_id", "")
                    if token_id:
                        update_env(f"{inst_dir}/.env", "NOVA_TOKEN", token_id)
                        update_env(f"{inst_dir}/.env", "NOVA_ENABLED", "true")
                        sp.finish(f"Agente creado: {token_id[:20]}...")
                        subprocess.run(["pm2", "restart", f"melissa-{name}"], capture_output=True)
                        return
        except Exception as e:
            pass
        sp.finish("No pude crear el agente — configura Nova manualmente con 'melissa nova'", ok=False)


def cmd_status(args):
    """Estado detallado de una instancia."""
    name = getattr(args, 'name', '') or ''
    print_logo(compact=True)

    instances = get_instances()
    if name:
        instances = [i for i in instances if name.lower() in i["name"].lower()]
    if not instances:
        fail(f"No encontré instancia '{name}'"); return

    for inst in instances:
        h = health(inst["port"])
        icon, status = get_status_icon(h)
        section(f"{inst.get('label', inst['name'])} {icon}")

        kv("Estado",     status.upper())
        kv("Puerto",     str(inst["port"]))
        kv("Directorio", inst["dir"])
        kv("PM2",        f"melissa-{inst['name']}" if not inst.get("is_base") else "melissa")

        if h:
            kv("Clínica",    h.get("clinic", "—"))
            kv("Plataforma", h.get("platform", "—"))
            wa = h.get("whatsapp", {})
            if wa.get("connected"):
                kv("WhatsApp",   wa.get("phone", "conectado"))
            kv("Memoria",    f"{h.get('memory_items', 0)} items")
            kv("Buffers",    str(h.get("active_buffers", 0)))
            kv("Nova",       "activo" if inst["env"].get("NOVA_ENABLED") == "true" else "inactivo")

        print()


def cmd_logs(args):
    """Logs en tiempo real de una instancia."""
    name = getattr(args, 'name', '') or ''
    print_logo(compact=True)

    if not name:
        instances = get_instances()
        opts = [f"{i['name']}  :{i['port']}" for i in instances]
        if not opts:
            fail("No hay instancias"); return
        idx = select(opts, title="¿De cuál instancia quieres ver los logs?")
