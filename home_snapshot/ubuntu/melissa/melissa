def cmd_delete(args):
    """Eliminar una instancia completamente."""
    name = getattr(args, 'name', '') or ''
    if not name:
        fail("Especifica el nombre: melissa delete clinica-bella"); return

    inst_dir = f"{INSTANCES_DIR}/{name}"
    if not os.path.isdir(inst_dir):
        fail(f"No existe instancia '{name}'"); return

    warn(f"Esto eliminará '{name}' y TODOS sus datos (conversaciones, DB, config)")
    typed = prompt(f"Escribe '{name}' para confirmar")
    if typed != name:
        info("Cancelado"); return

    pm2_name = f"melissa-{name}"
    pm2("delete", pm2_name)
    subprocess.run(["pm2", "save"], capture_output=True)
    shutil.rmtree(inst_dir, ignore_errors=True)
    ok(f"Instancia '{name}' eliminada permanentemente")


