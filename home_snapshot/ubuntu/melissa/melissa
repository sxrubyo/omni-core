def cmd_install(args):
    """Instalar 'melissa' como comando del sistema."""
    target = "/usr/local/bin/melissa"
    this   = os.path.abspath(__file__)

    try:
        if os.path.exists(target):
            os.remove(target)
        os.symlink(this, target)
        os.chmod(this, 0o755)
        ok(f"'melissa' instalado en {target}")
        info("Ahora puedes usar 'melissa' desde cualquier directorio")
        print()
        print("  " + q(C.P2, "Prueba:"))
        dim("  melissa list")
        dim("  melissa new")
        dim("  melissa chat")
        print()
    except PermissionError:
        fail("Necesitas sudo: sudo python3 melissa --install")
    except Exception as e:
        fail(f"Error: {e}")


