def nl_route(text):
    """
    Detecta intención del texto libre y redirige al comando correcto.
    'nuevo cliente' → cmd_new
    'ver clientes'  → cmd_list
    etc.
    """
    t = text.lower().strip()

    if any(w in t for w in ["nuevo", "new", "crear", "create", "cliente", "client"]):
        class A: name = ""
        cmd_new(A())
        return True

    if any(w in t for w in ["listar", "list", "ver", "show", "instancias"]):
        class A: pass
        cmd_list(A())
        return True

    if any(w in t for w in ["chat", "hablar", "lenguaje"]):
        parts = t.split()
        class A: name = parts[-1] if len(parts) > 1 else ""
        cmd_chat(A())
        return True

    if any(w in t for w in ["estado", "status", "health"]):
        parts = t.split()
        class A: name = parts[-1] if len(parts) > 1 else ""
        cmd_status(A())
        return True

    if any(w in t for w in ["log", "logs"]):
        parts = t.split()
        class A: name = parts[-1] if len(parts) > 1 else ""
        cmd_logs(A())
        return True

    if any(w in t for w in ["reiniciar", "restart"]):
        parts = t.split()
        class A: name = parts[-1] if len(parts) > 1 else ""
        cmd_restart(A())
        return True

    if any(w in t for w in ["omni", "monitoreo", "monitor"]):
        class A: subcommand = "chat"
        cmd_omni(A())
        return True

    if any(w in t for w in ["nova", "gobernanza"]):
        class A: subcommand = "status"
        cmd_nova(A())
        return True

    return False


