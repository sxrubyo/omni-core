# MAIN — router de comandos
# ══════════════════════════════════════════════════════════════════════════════

def main():
    parser = argparse.ArgumentParser(prog="melissa", add_help=False)
    parser.add_argument("command",    nargs="?", default="")
    parser.add_argument("subcommand", nargs="?", default="")
    parser.add_argument("name",       nargs="?", default="")
    parser.add_argument("--install",  action="store_true")
    parser.add_argument("--version",  "-V", action="store_true")
    parser.add_argument("--help",     "-h", action="store_true")
    args = parser.parse_args()

    if args.version:
        print(f"melissa {MELISSA_VERSION} ({MELISSA_BUILD})")
        return

    if args.install:
        cmd_install(args); return

    # Combinar subcommand en name si es necesario
    if args.subcommand and not args.name:
        args.name = args.subcommand

    cmd = args.command.lower().strip()

    routes = {
        "init":     cmd_init,
        "new":      cmd_new,
        "nuevo":    cmd_new,
        "list":     cmd_list,
        "listar":   cmd_list,
        "ls":       cmd_list,
        "status":   cmd_status,
        "estado":   cmd_status,
        "logs":     cmd_logs,
        "log":      cmd_logs,
        "restart":  cmd_restart,
        "reiniciar":cmd_restart,
        "stop":     cmd_stop,
        "detener":  cmd_stop,
        "delete":   cmd_delete,
        "eliminar": cmd_delete,
        "rm":       cmd_delete,
        "chat":     cmd_chat,
        "omni":     cmd_omni,
        "nova":     cmd_nova,
        "update":   cmd_update,
        "help":     cmd_help,
        "--help":   cmd_help,
        "":         cmd_help,
    }

    if args.help or cmd in ("help", "--help", ""):
        cmd_help(args)
        return

    if cmd in routes:
        routes[cmd](args)
    else:
        # Intentar lenguaje natural con el comando completo
        full_text = " ".join(filter(None, [cmd, args.subcommand, args.name]))
        if not nl_route(full_text):
            fail(f"Comando desconocido: '{cmd}'")
            info("Usa 'melissa help' para ver los comandos disponibles")
            info("O prueba en lenguaje natural: melissa 'nuevo cliente clinica bella'")


if __name__ == "__main__":
    main()
