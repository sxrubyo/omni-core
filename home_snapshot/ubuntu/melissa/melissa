def _e(code):
    if not sys.stdout.isatty() and not os.getenv("FORCE_COLOR"):
        return ""
    return f"\033[{code}m"

class C:
    R     = _e("0")       # reset
    BOLD  = _e("1")
    DIM   = _e("2")
    ITALIC= _e("3")

    # Purple palette (Melissa signature color)
    P1  = _e("38;5;183")  # Lavender — brightest
    P2  = _e("38;5;141")  # Soft purple
    P3  = _e("38;5;135")  # Medium purple
    P4  = _e("38;5;99")   # Deep purple
    P5  = _e("38;5;93")   # Dark purple — darkest

    # Text
    W   = _e("38;5;15")   # Pure white
    G0  = _e("38;5;252")  # Near white — primary text
    G1  = _e("38;5;248")  # Light gray
    G2  = _e("38;5;244")  # Mid gray
    G3  = _e("38;5;240")  # Dark gray

    # Semantic
    GRN = _e("38;5;114")  # Green
    RED = _e("38;5;203")  # Red
    YLW = _e("38;5;221")  # Yellow
    CYN = _e("38;5;117")  # Cyan

def q(color, text, bold=False):
    if bold:
        return f"{C.BOLD}{color}{text}{C.R}"
    return f"{color}{text}{C.R}"


