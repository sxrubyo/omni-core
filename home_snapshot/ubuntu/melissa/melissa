def load_env(path):
    env = {}
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith('#') and '=' in line:
                    k, _, v = line.partition('=')
                    env[k.strip()] = v.strip().strip('"').strip("'")
    except Exception:
        pass
    return env

def update_env(path, key, val):
    try:
        content = Path(path).read_text() if Path(path).exists() else ""
        if re.search(rf"^{key}=", content, re.MULTILINE):
            content = re.sub(rf"^{key}=.*$", f"{key}={val}", content, flags=re.MULTILINE)
        else:
            content += f"\n{key}={val}"
        Path(path).write_text(content)
    except Exception as e:
        warn(f"No pude actualizar .env: {e}")

def slug(name):
    name = name.lower().strip()
    for a, b in [("á","a"),("é","e"),("í","i"),("ó","o"),("ú","u"),("ñ","n"),("ü","u")]:
        name = name.replace(a, b)
    return re.sub(r'[^a-z0-9]+', '-', name).strip('-')

def next_free_port():
    import socket
    for p in range(BASE_PORT + 1, MAX_PORT + 1):
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            try:
                s.bind(("0.0.0.0", p))
                return p
            except OSError:
                continue
    return None

def get_instances():
    instances = []
    base_env = load_env(f"{MELISSA_DIR}/.env")
    if base_env:
        instances.append({
            "name": "base", "label": "instancia base",
            "port": int(base_env.get("PORT", BASE_PORT)),
            "dir": MELISSA_DIR, "env": base_env, "is_base": True,
        })
    if os.path.isdir(INSTANCES_DIR):
        for name in sorted(os.listdir(INSTANCES_DIR)):
            d = f"{INSTANCES_DIR}/{name}"
            ep = f"{d}/.env"
            if not os.path.isdir(d) or not os.path.exists(ep):
                continue
            env = load_env(ep)
            instances.append({
                "name": name, "label": name.replace("-", " ").title(),
                "port": int(env.get("PORT", 8002)),
                "dir": d, "env": env, "is_base": False,
            })
    return instances

def health(port, timeout=3):
    url = f"http://localhost:{port}/health"
    try:
        if _HTTPX:
            import httpx
            r = httpx.get(url, timeout=timeout)
            return r.json() if r.status_code == 200 else {}
        else:
            req = urllib.request.urlopen(url, timeout=timeout)
            return json.loads(req.read())
    except Exception:
        return {}

def pm2(cmd, name=""):
    args = ["pm2", cmd]
    if name: args.append(name)
    r = subprocess.run(args, capture_output=True, text=True)
    return r.returncode == 0

def pm2_exists(name):
    r = subprocess.run(["pm2", "describe", name], capture_output=True, text=True)
    return r.returncode == 0

def public_ip():
    try:
        if _HTTPX:
            import httpx
            return httpx.get("https://api.ipify.org", timeout=5).text.strip()
        else:
            return urllib.request.urlopen("https://api.ipify.org", timeout=5).read().decode().strip()
    except Exception:
        return ""

def get_status_icon(h):
    if not h:       return q(C.RED, "●"), "offline"
    status = h.get("status", "")
    if status == "online" or h.get("reachable"):  return q(C.GRN, "●"), "online"
    return q(C.RED, "●"), "offline"


