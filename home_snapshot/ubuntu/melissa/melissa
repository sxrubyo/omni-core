def prompt(label, default="", secret=False):
    d = f" [{default}]" if default else ""
    sys.stdout.write(f"\n  {q(C.P2,'?')}  {q(C.W, label)}{q(C.G3, d)}  ")
    sys.stdout.flush()
    try:
        import getpass
        val = getpass.getpass("") if secret else input("")
    except (EOFError, KeyboardInterrupt):
        print(); return default
    return val.strip() or default

def confirm(label, default=True):
    d = "S/n" if default else "s/N"
    sys.stdout.write(f"\n  {q(C.P2,'?')}  {q(C.W, label)} {q(C.G3, f'[{d}]')}  ")
    sys.stdout.flush()
    try:
        v = input("").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print(); return default
    if not v: return default
    return v in ("s", "si", "sí", "yes", "y")

def select(options, descriptions=None, title=""):
    if title:
        print(f"\n  {q(C.G2, title)}")
    for i, opt in enumerate(options):
        num = q(C.P2, f"{i+1}.", bold=True)
        desc = f"  {q(C.G3, descriptions[i])}" if descriptions and i < len(descriptions) else ""
        print(f"    {num}  {q(C.W, opt)}{desc}")
    while True:
        sys.stdout.write(f"\n  {q(C.P2,'→')}  ")
        sys.stdout.flush()
        try:
            v = input("").strip()
        except (EOFError, KeyboardInterrupt):
            print(); return 0
        if v.isdigit() and 1 <= int(v) <= len(options):
            return int(v) - 1
        warn("Escribe el número de la opción")


