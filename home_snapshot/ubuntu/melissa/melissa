def ghost_write(text, color=None, delay=0.018, prefix="  "):
    c = color or C.P2
    sys.stdout.write(prefix + C.BOLD + c)
    for ch in text:
        sys.stdout.write(ch)
        sys.stdout.flush()
        if ch in ".!?":    time.sleep(delay * 7)
        elif ch in ",:;":  time.sleep(delay * 3)
        elif ch == " ":    time.sleep(delay * 1.2)
        else:              time.sleep(delay + random.uniform(-0.004, 0.008))
    sys.stdout.write(C.R)
    print()


_SPINNER_FRAMES = ["⠋","⠙","⠹","⠸","⠼","⠴","⠦","⠧","⠇","⠏"]
_MELISSA_SPIN   = ["✦","✧","✦","✧"]

class Spinner:
    def __init__(self, msg, style="dots"):
        self.msg    = msg
        self.frames = _MELISSA_SPIN if style == "melissa" else _SPINNER_FRAMES
        self._stop  = threading.Event()
        self._t     = None

    def __enter__(self):
        self.start(); return self

    def __exit__(self, *a):
        self.finish()

    def start(self):
        def _run():
            i = 0
            while not self._stop.is_set():
                f = q(C.P2, self.frames[i % len(self.frames)], bold=True)
                sys.stdout.write(f"\r  {f}  {q(C.G1, self.msg)}")
                sys.stdout.flush()
                time.sleep(0.1)
                i += 1
        self._t = threading.Thread(target=_run, daemon=True)
        self._t.start()

    def update(self, msg):
        self.msg = msg

    def finish(self, msg=None, ok=True):
        self._stop.set()
        if self._t:
            self._t.join(timeout=0.5)
        icon = q(C.GRN, "✓") if ok else q(C.RED, "✗")
        sys.stdout.write(f"\r  {icon}  {q(C.W, msg or self.msg)}\n")
        sys.stdout.flush()


