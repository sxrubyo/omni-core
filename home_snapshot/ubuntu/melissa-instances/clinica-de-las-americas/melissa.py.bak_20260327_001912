    try:
        nova_rule_sync    = NovaRuleSync()
        log.info("[trainer] NovaRuleSync OK")
    except Exception as e:
        log.warning(f"[trainer] NovaRuleSync: {e}")

    log.info("═══ MELISSA TRAINER INITIALIZED ═══")


