        # ── Modo aprendizaje manual: el dueño está contando su negocio ───────────
        # Se activa cuando no había info en Google o fue corregida
        _learn_count = int(self._demo_sessions.get(blearn_key, -1))
        _in_learn_mode = (
            business_name and
