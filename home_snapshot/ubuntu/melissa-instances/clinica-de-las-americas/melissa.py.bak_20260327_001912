        prompt_evolver    = PromptEvolver()
        log.info("[trainer] PromptEvolver OK")
    except Exception as e:
        log.warning(f"[trainer] PromptEvolver: {e}")
    try:
        admin_client_mode = AdminClientMode()
        log.info("[trainer] AdminClientMode OK")
    except Exception as e:
