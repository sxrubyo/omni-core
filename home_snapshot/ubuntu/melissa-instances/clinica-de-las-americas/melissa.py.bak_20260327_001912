    WEEKDAY_NOTES: Dict[int, str] = {
        0: "lunes",    # Lunes — inicio de semana, energía variable
        1: "martes",   # Martes — semana en marcha
        2: "miércoles", # Miércoles — punto medio
        3: "jueves",   # Jueves — cerca del fin
