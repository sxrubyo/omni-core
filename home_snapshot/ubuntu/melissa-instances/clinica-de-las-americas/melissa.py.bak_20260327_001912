            if row:
                data = dict(row)
                # Parse JSON fields
                for field in ['services', 'schedule', 'holidays', 'persona_config', 
                             'business_rules', 'pricing', 'promotions', 
                             'admin_chat_ids', 'notification_settings']:
                    try:
