                f"Citas agendadas: {apts}",
                f"Clientes nuevos: {new_patients}",
            ]

            if top_intent:
                intent_labels = {
                    "appointment_request": "Agendar cita",
                    "price_inquiry": "Preguntar precios",
                    "service_info": "Info de servicios",
                    "greeting": "Saludos",
