class ResponseGenerator:
    """Generador de respuestas humanizadas."""
    
    def __init__(self, llm: LLMEngine):
        self.llm = llm
    
    async def generate(self,
                      message: str,
                      analysis: MessageAnalysis,
                      reasoning: Dict,
                      clinic: Dict,
                      patient: Dict,
                      history: List[Dict],
                      search_context: str = "",
                      personality: PersonalityProfile = None,
                      kb_context: str = "",
                      chat_id: str = "") -> str:
        """Genera respuesta óptima."""
        
        personality = personality or self._get_default_personality(clinic)
        
        system_prompt = self._build_system_prompt(
            clinic, patient, personality, search_context, reasoning, kb_context,
            chat_id=chat_id, history=history
        )
        
        messages = [{"role": "system", "content": system_prompt}]
        
        # Agregar historial
        for msg in history[-15:]:
            messages.append({
                "role": msg["role"],
                "content": msg["content"]
            })
        
        # Mensaje actual
        messages.append({"role": "user", "content": message})
        
        # Determinar modelo según complejidad
        model_tier = "fast"
        if analysis.intent in [IntentType.COMPLAINT, IntentType.EMERGENCY]:
            model_tier = "reasoning"
        elif reasoning.get("confidence", 1) < 0.6:
            model_tier = "reasoning"
        
        response, metadata = await self.llm.complete(
            messages,
            model_tier=model_tier,
            temperature=1.05,
            max_tokens=600
        )
        
        # Post-procesamiento
        response = self._postprocess(response, personality)
        
        return response
    
