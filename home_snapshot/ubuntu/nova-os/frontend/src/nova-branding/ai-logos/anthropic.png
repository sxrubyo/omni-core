<!DOCTYPE html><html lang="en" class="dark"> <head><meta charset="UTF-8"><meta name="description" content="The page you’re looking for doesn’t exist."><meta name="robots" content="index, follow, max-image-preview:large"><meta name="viewport" content="width=device-width"><link rel="icon" href="/favicon.ico"><meta name="generator" content="Astro v6.0.8"><title>Page Not Found | Zonalogo</title><script>
            // Initialize theme before hydration
            const theme = (() => {
                if (
                    typeof localStorage !== "undefined" &&
                    localStorage.getItem("theme")
                ) {
                    return localStorage.getItem("theme");
                }
                if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
                    return "dark";
                }
                return "light"; // Default to light if no preference
            })();

            if (theme === "light") {
                document.documentElement.classList.remove("dark");
            } else {
                document.documentElement.classList.add("dark");
            }
            window.localStorage.setItem("theme", theme);
        </script><!-- Canonical & Alternates --><link rel="canonical" href="https://zonalogo.com/download/anthropic-logo-transparent-background.png"><!-- Open Graph --><meta property="og:type" content="website"><meta property="og:url" content="https://zonalogo.com/download/anthropic-logo-transparent-background.png"><meta property="og:title" content="Page Not Found | Zonalogo"><meta property="og:description" content="The page you’re looking for doesn’t exist."><!-- Twitter --><meta property="twitter:card" content="summary_large_image"><meta property="twitter:url" content="https://zonalogo.com/download/anthropic-logo-transparent-background.png"><meta property="twitter:title" content="Page Not Found | Zonalogo"><meta property="twitter:description" content="The page you’re looking for doesn’t exist."><script>(function(){const gaId = "G-ESWNRVZNR3";
