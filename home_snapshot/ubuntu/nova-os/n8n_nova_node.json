{
  "name": "Nova Validate",
  "nodeColor": "#1a1a1a",
  "icon": "file:nova_icon.svg",
  "displayName": "Nova Validate",
  "description": "Validate AI agent actions against Nova governance rules",
  "documentation": "https://docs.nova-os.com/n8n",
  "subtitle": "Governance Layer",
  "inputs": ["main"],
  "outputs": ["main", "escalated"],
  "credentials": [
    {
      "name": "novaApi",
      "required": true
    }
  ],
  "properties": [
    {
      "displayName": "API Key",
      "name": "apiKey",
      "type": "credentials",
      "credentialType": "novaApi",
      "required": true,
      "description": "Nova API key for authentication"
    },
    {
      "displayName": "Action Description",
      "name": "actionDescription",
      "type": "string",
      "default": "",
      "required": true,
      "description": "The action or intent to validate (e.g., 'Send email to customer@example.com')"
    },
    {
      "displayName": "Agent Name",
      "name": "agentName",
      "type": "string",
      "default": "n8n Workflow",
      "description": "Name of the agent performing this action"
    },
    {
      "displayName": "Validation Type",
      "name": "validationType",
      "type": "options",
      "options": [
        {
          "name": "Full Validation (Score + Ledger)",
          "value": "full"
        },
        {
          "name": "Fast Check (Score Only)",
          "value": "fast"
        },
        {
          "name": "Duplicate Detection Only",
          "value": "duplicate"
        }
      ],
      "default": "full",
      "description": "How thorough should the validation be?"
    },
    {
      "displayName": "Require Approval",
      "name": "requireApproval",
      "type": "boolean",
      "default": true,
      "description": "If true, only APPROVED actions proceed. ESCALATED/BLOCKED stop the workflow."
    },
    {
      "displayName": "Output Mode",
      "name": "outputMode",
      "type": "options",
      "options": [
        {
          "name": "Full Response (score, reason, verdict, hash)",
          "value": "full"
        },
        {
          "name": "Verdict Only (APPROVED/BLOCKED/ESCALATED)",
          "value": "verdict"
        },
        {
          "name": "Score Only (0-100)",
          "value": "score"
        }
      ],
      "default": "full",
      "description": "What data to pass to the next node"
    }
  ],
  "methods": {
    "listSearch": {
      "getAgents": "https://api.nova-os.com/v1/agents/list"
    }
  }
}
