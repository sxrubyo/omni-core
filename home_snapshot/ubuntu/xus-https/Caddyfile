# =============================================================================
# CADDYFILE OPTIMIZADO PARA NEXUS
# Reverse Proxy + SSL Automático + Seguridad Reforzada
# =============================================================================
{
    # Email para certificados Let's Encrypt
    email admin@nexusys.duckdns.org
    
    # ESTA ES LA LÍNEA QUE FALTA:
    admin off
    # Logging global
    log {
        output stdout
        format console
        level INFO
    }
    
    # Configuración de servidores
    servers {
        protocols h1 h2 h2c h3
        timeouts {
            read_body 60s
            read_header 10s
            write 120s
            idle 300s
        }
    }
}

(nova_security) {
    encode gzip zstd
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        Cross-Origin-Opener-Policy "same-origin"
        Cross-Origin-Resource-Policy "same-site"
        Content-Security-Policy "default-src 'self' https: data: blob: 'unsafe-inline' 'unsafe-eval'; connect-src 'self' https: wss:; img-src 'self' https: data: blob:; font-src 'self' https: data:; style-src 'self' https: 'unsafe-inline'; script-src 'self' https: 'unsafe-inline' 'unsafe-eval' blob:; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
        -Server
        -X-Powered-By
    }
}

(nova_proxy) {
    handle /api/* {
        reverse_proxy 172.28.0.1:8000
    }
    reverse_proxy 172.28.0.1:3005
}
# Endpoint de salud para healthcheck (HTTP only)
:80 {
    respond /health 200
}
# Configuración principal HTTPS
nexusys.duckdns.org {
    # --- SSL/TLS ---
    tls {
        protocols tls1.2 tls1.3
    }
    # --- HEADERS DE SEGURIDAD ---
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
        -X-Powered-By
    }
    # --- COMPRESIÓN ---
    encode gzip zstd
    # --- LOGGING POR REQUEST ---
    log {
        output stdout
        format json {
            time_format iso8601
        }
    }

    # --- MELISSA BOT ---
    # 172.28.0.1 = gateway Docker hacia el host donde corre Melissa
    handle /telegram/* {
        reverse_proxy 172.28.0.1:8001
    }
    handle /health {
        reverse_proxy 172.28.0.1:8001
    }
    handle /setup-webhook {
        reverse_proxy 172.28.0.1:8001
    }

    # --- OMNI (puerto 9001) ---
    handle /omni/* {
        reverse_proxy 172.28.0.1:9001
    }

    # --- MELISSA INSTANCIAS ADICIONALES ---
    # Cada instancia tiene su propio puerto. Caddy enruta por path del webhook.
    # Patrón: /webhook/melissa_{nombre}_{secret} → puerto específico
    # Se agrega automáticamente cuando se crea una instancia nueva.
    # Instancia base Melissa
    handle /webhook/melissa_2026* {
        reverse_proxy 172.28.0.1:8001
    }

    # Instancias adicionales van aquí:
    # handle /webhook/melissa_x-bussines* {
    #     reverse_proxy 172.28.0.1:8002
    # }
    handle /webhook/melissa_clinica-de-las-americas_2ed44661cb56cd55* {
        reverse_proxy 172.28.0.1:8003
    }

    # --- REVERSE PROXY A N8N ---
    # Usa IP estática 172.28.0.50 o nombre de servicio n8n
    reverse_proxy 172.28.0.50:5678 {
        # Timeouts largos para workflows pesados
        transport http {
            dial_timeout 30s
            response_header_timeout 300s
            read_timeout 300s
            write_timeout 300s
            keepalive 120s
            keepalive_idle_conns 20
        }
        # Headers para proxy
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        header_up Connection "upgrade"
        header_up Upgrade {http.request.header.Upgrade}
        # Healthcheck activo
        health_uri /healthz
        health_interval 30s
        health_timeout 10s
        health_status 200
        # Flush inmediato para SSE/WebSocket
        flush_interval -1
    }
}

# Nova frontend listo para un dominio dedicado.
# Requiere crear este subdominio en DuckDNS y apuntarlo a este servidor.
novaops.duckdns.org {
    tls {
        protocols tls1.2 tls1.3
    }

    import nova_security

    log {
        output stdout
        format json {
            time_format iso8601
        }
    }

    import nova_proxy
}
