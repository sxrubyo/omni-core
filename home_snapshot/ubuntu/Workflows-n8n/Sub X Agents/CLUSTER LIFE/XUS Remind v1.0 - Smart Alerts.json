      "parameters": {
        "jsCode": "\nconst input = $input.first().json;\nconst query = (input.query || input.message?.text || input.text || '').trim();\nconst chatId = input.chatId || input.message?.chat?.id || '6908159885';\nreturn [{ json: { query, chatId, receivedAt: new Date().toISOString() } }];\n"
      },
      "id": "91e51ac1-8018-4138-bcd2-e6f5cc7bf5a9",
      "name": "📦 Input Parser",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        464,
