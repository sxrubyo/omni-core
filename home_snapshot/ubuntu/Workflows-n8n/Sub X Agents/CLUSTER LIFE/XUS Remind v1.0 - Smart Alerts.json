    {
      "parameters": {
        "jsCode": "\nconst bridge = $('🔗 Remind Bridge').first().json;\nconst cal = (() => { try { return $('📅 Google Calendar - Crear').first().json; } catch(e) { return {}; } })();\n\nconst typeLabels = { reminder: 'Recordatorio', followup: 'Follow-up', alert: 'Alerta', meeting: 'Reunión' };\n\nconst summary = bridge.typeEmoji + ' *' + (typeLabels[bridge.type] || 'Recordatorio') + ' programado*\\n\\n' +\n  '📝 *Mensaje:* ' + bridge.reminderMessage + '\\n' +\n  '🕐 *Cuándo:* ' + bridge.parsedTimeDesc + '\\n' +\n  '📅 *Evento creado en Google Calendar*\\n' +\n  '💾 *Backup en Sheets activo*\\n\\n' +\n  '_Te aviso por Telegram cuando llegue el momento._';\n\nreturn [{ json: {\n  output: summary,\n  toolResponse: 'Recordatorio programado: ' + bridge.reminderMessage + ' — ' + bridge.parsedTimeDesc,\n  reminderId: bridge.reminderId,\n  datetimeIso: bridge.datetimeIso,\n  calendarEventId: cal.id || null\n}}];\n"
      },
