    {
      "parameters": {
        "jsCode": "\nconst row = $input.first().json;\n\n// Construimos el payload exacto que XUS Talking espera\n// como si Santiago hubiera mandado un mensaje por Telegram\nconst typeEmoji = { reminder: '⏰', followup: '🔄', alert: '🚨', meeting: '📅' };\nconst emoji = typeEmoji[row.type] || '⏰';\n\n// Este mensaje llega al Cerebro Clasificador de XUS Talking\n// El clasificador lo reconocerá como SCHEDULE_REMINDER y lo procesará\nconst messageForXUS = 'SCHEDULE_REMINDER: ' + emoji + ' Recordatorio programado que acaba de vencer. ' +\n  'Mensaje: \"' + row.message + '\". ' +\n  'Tipo: ' + (row.type || 'reminder') + '. ' +\n  'Notifica al Arquitecto de forma natural con tu personalidad habitual. ' +\n  'Confirma el recordatorio con entusiasmo o urgencia según el tipo.';\n\nreturn [{ json: {\n  // Input que espera XUS Talking (mismo formato que los schedules de Begin)\n  message: {\n    text: messageForXUS,\n    chat: { id: row.chat_id || '6908159885' }\n  },\n  chatId: row.chat_id || '6908159885',\n  query: messageForXUS,\n  // Metadata para el log\n  _reminder_id: row.reminder_id,\n  _reminder_message: row.message,\n  _reminder_type: row.type,\n  _row_number: row.row_number,\n  _source: 'xus_remind_poller'\n}}];\n"
      },
