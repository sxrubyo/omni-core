    {
      "parameters": {
        "promptType": "define",
        "text": "={{ 'AHORA SON: ' + $now.toISO() + ' (Bogotá UTC-5)\\n\\nSOLICITUD: ' + $json.query }}",
        "needsFallback": true,
        "options": {
          "systemMessage": "Eres el parser de recordatorios de XUS. Tu única función es extraer los datos del recordatorio de la solicitud de Santiago y convertirlos en JSON.\n\nRESPONDE SOLO JSON PURO. Sin ```. Primera { última }\n\n═══ REGLAS DE TIEMPO ═══\nConvierte lenguaje natural a ISO 8601 en UTC-5 (Bogotá):\n- \"en 30 minutos\" → ahora + 30 min\n- \"en 1 hora\" → ahora + 1 hora\n- \"mañana a las 3pm\" → mañana 15:00\n- \"el viernes a las 10am\" → próximo viernes 10:00\n- \"en 2 horas\" → ahora + 2 horas\n- \"esta noche a las 9\" → hoy 21:00\n- \"pasado mañana\" → en 2 días\n- \"la próxima semana\" → en 7 días al mediodía\n\n═══ TIPOS ═══\n- \"recordatorio\" / \"recuérdame\" / \"avísame\" → reminder\n- \"follow-up\" / \"seguimiento\" → followup\n- \"alarma\" / \"alerta\" → alert\n- \"reunión\" / \"call\" / \"cita\" → meeting\n\n═══ OUTPUT ═══\n{\n  \"reminder_message\": \"texto exacto del recordatorio (qué debe recordar)\",\n  \"datetime_iso\": \"2026-02-22T15:00:00-05:00\",\n  \"type\": \"reminder|followup|alert|meeting\",\n  \"duration_minutes\": 30,\n  \"calendar_title\": \"titulo corto para el evento del calendario (max 50 chars)\",\n  \"calendar_description\": \"descripcion del evento con contexto\",\n  \"confidence\": \"high|medium|low\",\n  \"parsed_time_description\": \"descripción en español de cuándo (ej: mañana a las 3pm)\"\n}"
        }
      },
      "id": "d78a764a-fa72-4f9f-94c2-1774dad90a53",
      "name": "🧠 Gemini Time Parser",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        784,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst aiRaw = $input.first().json;\nconst inputData = $('📦 Input Parser').first().json;\n\nlet ai = {};\ntry {\n  let text = aiRaw.output || aiRaw.text || '';\n  if (typeof text !== 'string') text = JSON.stringify(text);\n  text = text.replace(/```json\\s*/gi,'').replace(/```\\s*/gi,'').trim();\n  const m = text.match(/\\{[\\s\\S]*\\}/);\n  if (m) ai = JSON.parse(m[0]);\n} catch(e) {\n  ai = {\n    reminder_message: inputData.query,\n    datetime_iso: new Date(Date.now() + 3600000).toISOString(),\n    type: 'reminder',\n    duration_minutes: 30,\n    calendar_title: 'Recordatorio XUS',\n    calendar_description: inputData.query,\n    confidence: 'low',\n    parsed_time_description: 'en 1 hora (fallback)'\n  };\n}\n\n// Generar ID único para este recordatorio\nconst reminderId = 'REM_' + Date.now() + '_' + Math.random().toString(36).substr(2,5).toUpperCase();\n\n// Emojis por tipo\nconst typeEmoji = { reminder: '⏰', followup: '🔄', alert: '🚨', meeting: '📅' };\n\nreturn [{ json: {\n  reminderId,\n  reminderMessage: ai.reminder_message || inputData.query,\n  datetimeIso: ai.datetime_iso,\n  type: ai.type || 'reminder',\n  typeEmoji: typeEmoji[ai.type] || '⏰',\n  durationMinutes: ai.duration_minutes || 30,\n  calendarTitle: ai.calendar_title || 'Recordatorio XUS',\n  calendarDescription: ai.calendar_description || ai.reminder_message || inputData.query,\n  confidence: ai.confidence || 'medium',\n  parsedTimeDesc: ai.parsed_time_description || 'hora extraída',\n  chatId: inputData.chatId,\n  query: inputData.query,\n  receivedAt: inputData.receivedAt\n}}];\n"
      },
