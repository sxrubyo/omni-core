    {
      "parameters": {
        "jsCode": "\nconst rows = $input.all();\nconst now = new Date();\n\nconst due = rows.filter(r => {\n  const row = r.json;\n  if (String(row.fired).toUpperCase() === 'TRUE') return false;\n  if (!row.datetime_fire) return false;\n  return new Date(row.datetime_fire) <= now;\n});\n\nif (due.length === 0) return [{ json: { _has_due: false } }];\n\ndue[0].json._has_due = true;\nreturn due;\n"
      },
