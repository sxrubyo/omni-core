# =============================================================================
# CADDYFILE OPTIMIZADO PARA NEXUS
# Reverse Proxy + SSL Automático + Seguridad Reforzada
# ==========================================================================
{
    # Email para certificados Let's Encrypt
    email admin@nexusys.duckdns.org
    
    # ESTA ES LA LÍNEA QUE FALTA:
    admin off

    # Logging global
    log {
        output stdout
        format console
        level INFO
    }
    
    # Configuración de servidores
    servers {
        protocols h1 h2 h2c h3
        timeouts {
            read_body 60s
            read_header 10s
            write 120s
            idle 300s
        }
    }
}

# Endpoint de salud para healthcheck (HTTP only)
:80 {
    respond /health 200
}

# Configuración principal HTTPS
nexusys.duckdns.org {
    # --- SSL/TLS ---
    tls {
        protocols tls1.2 tls1.3
    }

    # --- HEADERS DE SEGURIDAD ---
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
        -X-Powered-By
    }

    # --- COMPRESIÓN ---
    encode gzip zstd

    # --- LOGGING POR REQUEST ---
    log {
        output stdout
        format json {
            time_format iso8601
        }
    }
    
    # --- REVERSE PROXY A N8N ---
    # Usa IP estática 172.28.0.50 o nombre de servicio n8n
    reverse_proxy 172.28.0.50:5678 {
        # Timeouts largos para workflows pesados
        transport http {
            dial_timeout 30s
            response_header_timeout 300s
            read_timeout 300s
            write_timeout 300s
            keepalive 120s
            keepalive_idle_conns 20
        }

        # Headers para proxy
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        header_up Connection "upgrade"
        header_up Upgrade {http.request.header.Upgrade}

        # Healthcheck activo
        health_uri /healthz
        health_interval 30s
        health_timeout 10s
        health_status 200

        # Flush inmediato para SSE/WebSocket
        flush_interval -1
    }
}
