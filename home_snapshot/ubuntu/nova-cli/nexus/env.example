# ═══════════════════════════════════════════════════════════
#  NEXUS STACK — Variables de entorno
#  Renombrar este archivo a .env antes de hacer deploy
#  NUNCA subir este archivo a Git
# ═══════════════════════════════════════════════════════════

# ─── DOMINIO ─────────────────────────────────────────────
N8N_HOST=tudominio.com                  # ej: nexus.midominio.com

# ─── POSTGRES ────────────────────────────────────────────
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURO
POSTGRES_DB=nexus_db

# ─── N8N ─────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=CAMBIAR_PASSWORD_SEGURO
N8N_ENCRYPTION_KEY=GENERAR_32_CHARS_RANDOM   # openssl rand -hex 16

# ─── PROXY (HP via Tailscale) ────────────────────────────
PROXY_HOST=100.84.255.20
PROXY_PORT=808
